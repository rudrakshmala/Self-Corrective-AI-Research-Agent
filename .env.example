# ── Groq ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...

# ── Tavily Web Search ─────────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-...

# ── Logfire Observability ─────────────────────────────────────────────────────
LOGFIRE_TOKEN=...

# ── LangSmith Tracing (optional) ──────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=self-corrective-rag

# ── Model Configuration ───────────────────────────────────────────────────────
ROUTER_MODEL=llama3-8b-8192
GENERATOR_MODEL=llama3-70b-8192
GRADER_MODEL=llama3-8b-8192
EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2
TEMPERATURE=0.0

# ── RAG Configuration ─────────────────────────────────────────────────────────
TOP_K_DOCS=4
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ── Graph Control ─────────────────────────────────────────────────────────────
MAX_ITERATIONS=3
HALLUCINATION_THRESHOLD=0.5

# ── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=rag_documents
